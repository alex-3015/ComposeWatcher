{
  "name": "@composewatcher/frontend",
  "version": "3.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:mock": "cross-env MOCK=true vite",
    "build": "npm run typecheck && vite build",
    "typecheck": "vue-tsc --noEmit && tsc --noEmit -p tsconfig.tools.json",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "lint": "eslint src/ mock-plugin.ts vite.config.ts playwright.config.ts tests/",
    "lint:fix": "eslint src/ mock-plugin.ts vite.config.ts playwright.config.ts tests/ --fix",
    "format": "prettier --check \"src/**/*.{ts,vue}\" \"tests/**/*.ts\" \"*.ts\"",
    "format:fix": "prettier --write \"src/**/*.{ts,vue}\" \"tests/**/*.ts\" \"*.ts\"",
    "docker:build": "docker build -t composewatcher:latest -f ../Dockerfile .. && node --input-type=commonjs -e \"require('fs').mkdirSync('../dist',{recursive:true})\" && docker save composewatcher:latest -o ../dist/composewatcher.tar && echo Image saved to dist/composewatcher.tar"
  },
  "dependencies": {
    "@lucide/vue": "^1.24.0",
    "dompurify": "^3.4.12",
    "marked": "^18.0.6",
    "vue": "^3.5.39"
  },
  "devDependencies": {
    "@composewatcher/contracts": "3.0.0",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^24.0.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.10",
    "@vue/test-utils": "^2.4.11",
    "cross-env": "^10.1.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.2",
    "happy-dom": "^20.10.6",
    "prettier": "^3.9.5",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.3.7"
  }
}
