{
  "name": "composewatcher-frontend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:mock": "cross-env MOCK=true vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --check \"src/**/*.{ts,vue}\"",
    "format:fix": "prettier --write \"src/**/*.{ts,vue}\"",
    "docker:build": "docker build -t composewatcher:latest -f ../Dockerfile .. && node --input-type=commonjs -e \"require('fs').mkdirSync('../dist',{recursive:true})\" && docker save composewatcher:latest -o ../dist/composewatcher.tar && echo Image saved to dist/composewatcher.tar"
  },
  "dependencies": {
    "dompurify": "^3.3.3",
    "lucide-vue-next": "^0.468.0",
    "marked": "^18.0.0",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@types/dompurify": "^3.0.5",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vitest/coverage-v8": "^4.1.4",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.20",
    "cross-env": "^10.1.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.8.0",
    "happy-dom": "^20.8.3",
    "postcss": "^8.4.49",
    "prettier": "^3.8.2",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.58.1",
    "vite": "^6.4.1",
    "vitest": "^4.0.18",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^2.2.0"
  }
}
